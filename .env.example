# Smart Queue Monorepo - Environment Variables Example
# Copy this file to .env and fill in the values

# --- Backend Configuration ---
# PostgreSQL Database Settings (used by queue-api)
DB_USER="postgres"
DB_PASSWORD="your_password_here"
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="smart_queue"

# Redis Server URL (used by queue-api and live-board-api)
REDIS_URL="redis://localhost:6379"

# API Port (queue-api)
PORT=3001

# WebSocket Port (live-board-api)
WS_PORT=3002

# Allowed CORS Origins (comma separated)
CORS_ORIGIN="http://localhost:3000,http://localhost:3003"


# --- Frontend Configuration ---
# Admin Web & Public Web (Next.js)
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3002"
